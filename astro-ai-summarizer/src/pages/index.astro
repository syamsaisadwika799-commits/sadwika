---
import { supabase } from '../lib/supabase';
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>AI Article Summarizer</title>
	</head>
	<body class="bg-slate-50 min-h-screen font-sans text-slate-900 antialiased selection:bg-indigo-100 selection:text-indigo-900">
		
		<header class="bg-white border-b border-slate-200 sticky top-0 z-10 shadow-sm">
			<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
				<div class="flex items-center space-x-3">
					<div class="bg-indigo-600 text-white p-2 rounded-xl shadow-inner">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
					</div>
					<h1 class="text-xl font-extrabold tracking-tight text-slate-900">AI Summarizer</h1>
				</div>
				<nav class="flex space-x-4 text-sm font-medium">
					<a href="#" class="text-slate-500 hover:text-slate-900 transition-colors">History</a>
					<a href="#" class="text-slate-500 hover:text-slate-900 transition-colors">Settings</a>
				</nav>
			</div>
		</header>

		<main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
			<div class="text-center mb-10">
				<h2 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">Digest articles <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 to-cyan-500">in seconds</span></h2>
				<p class="mt-4 max-w-2xl text-lg text-slate-500 mx-auto">Paste any long article, document, or wall of text below, and our AI will generate a concise, readable summary instantly.</p>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
				{/* Input Section */}
				<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden flex flex-col transition-shadow hover:shadow-md h-[32rem]">
					<div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
						<h3 class="text-sm font-bold text-slate-800 uppercase tracking-wider flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
							Original Text
						</h3>
						<span id="charCount" class="text-xs font-medium text-slate-400 bg-slate-100 px-2 py-1 rounded-full">0 chars</span>
					</div>
					<textarea 
						id="article-input" 
						class="flex-1 w-full bg-transparent p-6 text-slate-700 focus:outline-none focus:ring-0 resize-none leading-relaxed"
						placeholder="Paste your long article or text here..."
					></textarea>
					<div class="p-4 border-t border-slate-100 bg-slate-50">
						<button 
							id="summarize-btn"
							class="w-full flex items-center justify-center gap-2 bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-700 hover:to-blue-700 text-white font-semibold py-3 px-6 rounded-xl shadow-sm transition-all hover:shadow transform hover:-translate-y-0.5 active:translate-y-0 disabled:opacity-50 disabled:cursor-not-allowed"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72Z"/><path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/></svg>
							<span id="btn-text">Summarize Text</span>
							<svg id="loading-spinner" class="animate-spin -ml-1 mr-3 h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
						</button>
					</div>
				</div>

				{/* Output Section */}
				<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden flex flex-col transition-shadow hover:shadow-md h-[32rem]">
					<div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
						<h3 class="text-sm font-bold text-slate-800 uppercase tracking-wider flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-500"><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72Z"/><path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/></svg>
							AI Summary
						</h3>
						<button id="copy-btn" class="text-slate-400 hover:text-slate-600 transition-colors hidden" title="Copy to clipboard">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
						</button>
					</div>
					<div id="summary-output" class="flex-1 p-6 overflow-y-auto text-slate-700 leading-relaxed text-lg prose prose-slate">
						<div class="h-full flex flex-col items-center justify-center text-slate-400 space-y-4">
							<div class="bg-slate-50 p-4 rounded-full border border-slate-100">
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72Z"/><path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/></svg>
							</div>
							<p class="text-sm font-medium">Your summary will appear here</p>
						</div>
					</div>
				</div>
			</div>
		</main>

		<!-- Setup supabase client for frontend -->
		<script>
			import { createClient } from "@supabase/supabase-js";
			
			// Initialize supabase inside the script tag using imported env vars is tricky in vanilla inside astro file.
			// Better way: expose an API or use the imported supabase client from another file.
		</script>
		<script>
			import { supabase } from '../lib/supabase';

			const input = document.getElementById('article-input') as HTMLTextAreaElement;
			const btn = document.getElementById('summarize-btn') as HTMLButtonElement;
			const btnText = document.getElementById('btn-text');
			const spinner = document.getElementById('loading-spinner');
			const output = document.getElementById('summary-output');
			const charCount = document.getElementById('charCount');
			const copyBtn = document.getElementById('copy-btn');

			let currentSummary = '';

			input?.addEventListener('input', () => {
				if(charCount) {
					charCount.textContent = `${input.value.length} chars`;
				}
				if(btn) {
					btn.disabled = input.value.trim().length === 0;
				}
			});

			copyBtn?.addEventListener('click', () => {
				if(currentSummary) {
					navigator.clipboard.writeText(currentSummary);
					const prevHTML = copyBtn.innerHTML;
					copyBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
					setTimeout(() => {
						copyBtn.innerHTML = prevHTML;
					}, 2000);
				}
			});

			btn?.addEventListener('click', async () => {
				const text = input.value.trim();
				if (!text) return;

				// UI Loading state
				btn.disabled = true;
				if(btnText) btnText.classList.add('hidden');
				if(spinner) spinner.classList.remove('hidden');
				if(output) output.innerHTML = '<div class="h-full flex items-center justify-center"><div class="flex space-x-2"><div class="w-3 h-3 bg-indigo-500 rounded-full animate-bounce" style="animation-delay: 0s"></div><div class="w-3 h-3 bg-indigo-500 rounded-full animate-bounce" style="animation-delay: 0.2s"></div><div class="w-3 h-3 bg-indigo-500 rounded-full animate-bounce" style="animation-delay: 0.4s"></div></div></div>';
				if(copyBtn) copyBtn.classList.add('hidden');

				try {
					const res = await fetch('/api/summarize', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ text })
					});

					const data = await res.json();

					if (data.error) throw new Error(data.error);

					currentSummary = data.summary;
					if(output) output.innerHTML = `<div class="animate-fade-in"><p class="whitespace-pre-line">${data.summary}</p></div>`;
					if(copyBtn) copyBtn.classList.remove('hidden');

					// Save to Supabase (Background)
					if (import.meta.env.PUBLIC_SUPABASE_URL) {
						supabase.from('summaries').insert({
							original_text: text,
							summary_text: data.summary,
						}).then(({error}) => {
							if(error) console.error("Error saving to supabase:", error);
						});
					}

				} catch (error: any) {
					console.error(error);
					if(output) output.innerHTML = `<div class="text-red-500 p-4 bg-red-50 rounded-lg flex items-start gap-3 border border-red-100"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><div><h4 class="font-bold">Error generating summary</h4><p class="text-sm mt-1">${error.message}</p></div></div>`;
				} finally {
					btn.disabled = false;
					if(btnText) btnText.classList.remove('hidden');
					if(spinner) spinner.classList.add('hidden');
				}
			});
			
			// Initial check
			if(btn && !input?.value) {
				btn.disabled = true;
			}
		</script>
	</body>
</html>
